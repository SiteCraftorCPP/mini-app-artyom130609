# Скопируйте в bot/.env на сервере и подставьте токен.
# Полный пример путей сервера: /srv/artshopvirts/mini-app-artyom130609/bot/

TELEGRAM_BOT_TOKEN=

# Если фото не находится — абсолютный путь к папке bot (редко нужно):
# BOT_INSTALL_ROOT=/srv/artshopvirts/mini-app-artyom130609/bot

MINI_APP_URL=https://artshopvirts.space

# /start — три стикера. Важно: цифры из «ботов с ID» — это custom_emoji_id, для sendSticker нужны file_id
# (в ответе API поле file_id, обычно CAAC…). Самый надёжный вариант — прописать file_id в .env:
# WELCOME_STICKER_FILE_IDS=file_id1,file_id2,file_id3
# HOW_STICKER_FILE_ID=file_id_молния
# ABOUT_STICKER_FILE_IDS=файл1,файл2,файл3,файл4
# (получение: переслать КАЖДЫЙ нужный стикер своему боту и в логе / getUpdates взять message.sticker.file_id)
# Если не задано — бот вызывает getCustomEmojiStickers(id из bot/src/sticker-ids.ts); иначе баннер:
# WELCOME_PHOTO_URL=https://...
# WELCOME_PHOTO_PATH=images/welcome.jpg

# Фото «заказ оформлен» — положите файл в bot/images/ под одним из имён:
# order-success.jpg | order-success.png | order.jpg | order.png
# или photo_2026-04-07_20-21-21.jpg / .png
# Если имя своё:
# ORDER_SUCCESS_IMAGE_PATH=images/ваш-файл.jpg
# или абсолютный путь:
# ORDER_SUCCESS_IMAGE_PATH=/srv/artshopvirts/mini-app-artyom130609/bot/images/ваш-файл.jpg

# Мини-апп шлёт orderKind: virt | account. Для account по умолчанию:
# WebApp-кнопка «Узнать детали» на /profile?open=currentOrders&orderId=… (как у виртов).
# Только если нужен сценарий через менеджера (кнопка-ссылка t.me, не WebApp):
# ACCOUNT_ORDER_TEMPLATE=manager
# MANAGER_TELEGRAM_URL=https://t.me/artshopvirts_man
