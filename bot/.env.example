# Скопируйте в bot/.env на сервере и подставьте токен.
# Полный пример путей сервера: /srv/artshopvirts/mini-app-artyom130609/bot/

TELEGRAM_BOT_TOKEN=

# Админы: уведомление в личку при каждом новом заказе (оформление в мини-аппе). Можно несколько через запятую.
# TELEGRAM_ADMIN_ID=123456789
# TELEGRAM_ADMIN_IDS=111,222

# Если фото не находится — абсолютный путь к папке bot (редко нужно):
# BOT_INSTALL_ROOT=/srv/artshopvirts/mini-app-artyom130609/bot

# Также: кнопка «Магазин» в поле ввода (setChatMenuButton) открывает этот же Web App.
MINI_APP_URL=https://artshopvirts.space

# === FreeKassa (личный кабинет merchant.freekassa.net → «Настройки») ===
# 1) URL оповещения в ЛК FreeKassa: https://ВАШ_ДОМЕН/notify/freekassa
#    Nginx: см. deploy/nginx/notify.conf — весь префикс /notify/ → 127.0.0.1:ORDER_NOTIFY_HTTP_PORT
# 2) Метод оповещения: как в ЛК — GET или POST (бот принимает оба)
# 3) URL сайта / Mini App: ваш реальный HTTPS (как в BotFather)
# 4) Включить способы оплаты: СБП, МИР, Card RUB (как в разделе валют магазина)
# Секреты из ЛК (два разных поля!):
#   «Секретное слово»        → FREEKASSA_SECRET1  (подпись ссылки на оплату)
#   «Секретное слово 2»       → FREEKASSA_SECRET2 (подпись уведомления после оплаты)
FREEKASSA_MERCHANT_ID=68224
# Если в секрете спецсимволы (?, [], # и т.д.) — в .env и в systemd укажите в кавычках, иначе значение обрежется:
# FREEKASSA_SECRET1="вставьте_секрет_1"
FREEKASSA_SECRET1=
FREEKASSA_SECRET2=
# API-ключ из ЛК (настройки магазина) + ОБА секрета — для @boarteam/freekassa-sdk (POST https://api.fk.life/v1/orders/create по док-ции). Без пары FREEKASSA_API_KEY + FREEKASSA_SECRET1 + FREEKASSA_SECRET2 — только GET pay.fk.money.
# FREEKASSA_API_KEY=
# ID способа оплаты `i` в ссылке pay.fk.money — возьми из ЛК (список валют / способы), если отличается от дефолтов в коде:
# FREEKASSA_METHOD_SBP=44
# FREEKASSA_METHOD_CARD=36
# FREEKASSA_METHOD_MIR=12
# Если в ЛК для способа нужен телефон (см. getCurrencies → fields), задайте E.164, например +79001234567:
# FREEKASSA_ORDER_TEL=
# FREEKASSA_SKIP_IP_CHECK=1

# custom_emoji_id (длинные цифры) в подписи/тексте + entities; обычный .webp: file_id (CAAC…)
#
# /start: подпись к баннеру — ровно 2 custom_emoji_id:
# 1) в начале 1-й строки (вместо 👋), 2) в конце 2-й строки (вместо 👇)
WELCOME_STICKER_FILE_IDS=5402498632739996967,5231102735817918643

# Перед видео «Как оформить заказ» — одна молния
HOW_STICKER_FILE_ID=5323761960829862762

# «О магазине»: 4 строки — доллар, молния, бары, цепь (как 🪙⚡🍑⛓)
ABOUT_STICKER_FILE_IDS=5283232570660634549,5323761960829862762,5258330865674494479,5260730055880876557

# «Заказ оформлен» (подпись к фото) — ровно 3 custom_emoji_id:
# 1) в начале 1-й строки (как ✅), 2) у строки срока (как 🕔), 3) в конце последней (как 👇)
ORDER_SUCCESS_STICKER_IDS=5233307140667492238,5258419835922030550,5231102735817918643

# Менеджер / «Продать вирты» (подпись к тому же фото) — 2 id, без срока выдачи:
# 1) в начале 1-й строки (как ✅), 2) в конце «…через кнопку ниже» (как 👇)
ORDER_SUCCESS_MANAGER_STICKER_IDS=5233307140667492238,5231102735817918643

# Выполнение заказа (подпись к images/photo_3.*) — ровно 3 custom_emoji_id:
# 1) «Заказ #… выполнен» (как ✅), 2) «Вирты / данные аккаунта» (как ✅), 3) «Напишите отзыв…» (как 🪙)
ORDER_COMPLETED_STICKER_IDS=5208540237524911208,5260726538302660868,5283232570660634549
# Fallback, если /start-стикеры не отправились (нет WELCOME_STICKER_FILE_IDS / ошибка API):
# WELCOME_PHOTO_URL=https://...
# WELCOME_PHOTO_PATH=images/welcome.jpg
#
# «О магазине» — в одном стиле с WELCOME_PHOTO_PATH / ORDER_* (абсолютно до файла в /srv/.../images/ или относительно bot/):
# ABOUT_SHOP_PHOTO_PATH=/srv/artshopvirts/mini-app-artyom130609/images/photo_4.jpg
# ABOUT_SHOP_PHOTO_PATH=images/photo_4.jpg
# ABOUT_SHOP_PHOTO_URL=https://...

# Фото «заказ оформлен» — положите файл в bot/images/ под одним из имён:
# order-success.jpg | order-success.png | order.jpg | order.png
# или photo_2026-04-07_20-21-21.jpg / .png
# Если имя своё:
# ORDER_SUCCESS_IMAGE_PATH=images/ваш-файл.jpg
# или абсолютный путь:
# ORDER_SUCCESS_IMAGE_PATH=/srv/artshopvirts/mini-app-artyom130609/bot/images/ваш-файл.jpg

# Мини-апп шлёт orderKind: virt | account. Для account по умолчанию:
# WebApp «Узнать детали» → /profile?open=orderHistory (список заказов, без id — карточка часто пуста).
# Только если нужен сценарий через менеджера (кнопка-ссылка t.me, не WebApp):
# ACCOUNT_ORDER_TEMPLATE=manager
# MANAGER_TELEGRAM_URL=https://t.me/artshopvirts_man
