# Скопируйте в bot/.env на сервере и подставьте токен.
# Полный пример путей сервера: /srv/artshopvirts/mini-app-artyom130609/bot/

TELEGRAM_BOT_TOKEN=

# Таймаут HTTP к api.telegram.org (сек), по умолчанию 180. Если сеть «дует», не ставьте слишком мало — getUpdates может ждать до ~50 с.
# TELEGRAM_API_FETCH_TIMEOUT_SECONDS=180

# Админы: уведомление в личку при каждом новом заказе (оформление в мини-аппе). Можно несколько через запятую.
# Без TELEGRAM_ADMIN_ID / TELEGRAM_ADMIN_IDS уведомления о новых заказах админам не отправляются (в логах будет предупреждение).
# TELEGRAM_ADMIN_ID=123456789
# TELEGRAM_ADMIN_IDS=111,222

# Канал для новых заказов (оплата / оформление в мини-аппе). Бот должен быть админом канала.
# ORDERS_CHANNEL_ID=-1001234567890

# Отдельный канал: после ввода чистой прибыли (закрытие заказа).
# Формат: Номер заказа / Оборот / Чистая прибыль / Покупатель.
# ORDER_COMPLETION_CHANNEL_ID=-1009876543210

# Если фото не находится — абсолютный путь к папке bot (редко нужно):
# BOT_INSTALL_ROOT=/srv/artshopvirts/mini-app-artyom130609/bot

# Каталог «Другие услуги» (JSON). Если `bot/data` read-only, задай путь, куда пишет пользователь бота, например:
# OTHER_SERVICES_V1_PATH=/var/lib/artshopvirts/other-services.v1.json
# либо каталог: BOT_DATA_DIR=/var/lib/artshopvirts
# Без env при EACCES к bot/data пишет в ~/.artshopvirts/other-services.v1.json (под пользователем systemd).

# Также: кнопка «Магазин» в поле ввода (setChatMenuButton) открывает этот же Web App.
MINI_APP_URL=https://artshopvirts.space

# === FreeKassa (личный кабинет merchant.freekassa.net → «Настройки») ===
# 1) URL оповещения в ЛК FreeKassa: https://ВАШ_ДОМЕН/notify/freekassa
#    Nginx: см. deploy/nginx/notify.conf — весь префикс /notify/ → 127.0.0.1:ORDER_NOTIFY_HTTP_PORT
# 2) Метод оповещения: как в ЛК — GET или POST (бот принимает оба)
# 3) URL сайта / Mini App: ваш реальный HTTPS (как в BotFather)
# 4) Включить способы оплаты: СБП, МИР, Card RUB (как в разделе валют магазина)
# Секреты из ЛК (два разных поля!):
#   «Секретное слово»        → FREEKASSA_SECRET1  (подпись ссылки на оплату)
#   «Секретное слово 2»       → FREEKASSA_SECRET2 (подпись уведомления после оплаты)
FREEKASSA_MERCHANT_ID=68224
# Если в секрете спецсимволы (?, [], # и т.д.) — в .env и в systemd укажите в кавычках, иначе значение обрежется:
# FREEKASSA_SECRET1="вставьте_секрет_1"
FREEKASSA_SECRET1=
FREEKASSA_SECRET2=
# API-ключ из ЛК (настройки магазина) + ОБА секрета — для @boarteam/freekassa-sdk (POST https://api.fk.life/v1/orders/create по док-ции). Без пары FREEKASSA_API_KEY + FREEKASSA_SECRET1 + FREEKASSA_SECRET2 — только GET pay.fk.money.
# FREEKASSA_API_KEY=
# ID способа оплаты `i` в ссылке pay.fk.money — возьми из ЛК (список валют / способы), если отличается от дефолтов в коде:
# FREEKASSA_METHOD_SBP=44
# FREEKASSA_METHOD_CARD=36
# FREEKASSA_METHOD_MIR=12
# Если в ЛК для способа нужен телефон (см. getCurrencies → fields), задайте E.164, например +79001234567:
# FREEKASSA_ORDER_TEL=
# FREEKASSA_SKIP_IP_CHECK=1

# StreamPay — дока: https://api.streampay.org (POST /api/payment/create, заголовки signature + Content-type).
# system_currency в примере — USDT, payment_type=2; подпись: тело JSON + UTC YYYYMMDD:HHMM.
# Ed25519: STREAMPAY_PRIVATE_KEY_HEX (64 hex seed; ЛК StreamPay иногда даёт 128 = private+public — можно целиком),
# STREAMPAY_PUBLIC_KEY_HEX (64 hex) — из кабинета.
# STREAMPAY_API_BASE_URL=https://api.streampay.org
# STREAMPAY_STORE_ID=
# STREAMPAY_PRIVATE_KEY_HEX=
# STREAMPAY_PUBLIC_KEY_HEX=
# Логи: каждый create пишет в stderr [streampay] payment/create bodyJson; при ошибке — полный ответ API. Расширенно: STREAMPAY_LOG=1
# Проверка .env: npm run diag:streampay-env
# STREAMPAY_LOG=1
# UAH строкой даёт 406 — задай числовой ISO в JSON: STREAMPAY_JSON_CURRENCY_AS_ISO4217_NUMBER=1 (в теле будет 980)
# Если API ждёт строку "980": ещё STREAMPAY_ISO4217_NUMERIC_AS_JSON_STRING=1
# Если API ждёт строки: STREAMPAY_PAYMENT_TYPE_AS_JSON_STRING=1 и/или STREAMPAY_AMOUNT_AS_JSON_STRING=1
# Обязательно (или одной строкой EXTRA ниже), как в официальном примере:
# STREAMPAY_SYSTEM_CURRENCY=USDT
# STREAMPAY_PAYMENT_TYPE=2
# При payment_type=1 ещё:
# STREAMPAY_CURRENCY=…
# Опционально: только ДОПОЛНИТЕЛЬНЫЕ поля из примера ЛК (fee_payer и т.д.) — НЕ system_currency/payment_type/currency (их задаёт бот из строк выше).
# STREAMPAY_EXTRA_CREATE_FIELDS={"fee_payer":"customer"}
# --- Сумма счёта: STREAMPAY_ORDER_RUB_TO_INVOICE_RATE (юнитов system_currency за 1 ₽) ИЛИ при STREAMPAY_AUTO_FIAT_RATES
# пересчёт ₽ → system_currency по ЦБ (для USDT курс как USD). Кэш: STREAMPAY_CBR_CACHE_SEC=3600
# Кнопки ТЕНГЕ/ГРИВНЫ/BYN/AZN в мини-аппе только для подписи заказа у вас; в API StreamPay уходит как в ЛК (USDT + payment_type 2 и т.д.)
# STREAMPAY_AUTO_FIAT_RATES=1
# USDT + type 2: по умолчанию сумма округляется вверх до целого USDT (1.33→2), из‑за amount_is_invalid у API. Оставить копейки: STREAMPAY_INVOICE_USDT_ALLOW_FRACTION=1
# При повторном amount_is_invalid (например 2 USDT) — повтор create с +1 USDT до N раз: STREAMPAY_AMOUNT_INVALID_MAX_TRIES=15 (макс. 40)
# При 406 на мелкой сумме: STREAMPAY_MIN_INVOICE_USDT=… (только если ЛК требует)
# Экран выбора валюты на pay_url: в официальном create для type 2 этого нет; если поддержка назовёт query-параметр — STREAMPAY_PAY_URL_FIAT_PARAM=currency STREAMPAY_PAY_URL_FIAT_VALUE=KZT (VALUE можно не задавать — подставится KZT/UAH/… с кнопки)
# Редиректы после оплаты (опционально):
# STREAMPAY_SUCCESS_URL=https://...
# STREAMPAY_FAIL_URL=https://...
# STREAMPAY_CANCEL_URL=https://...
# STREAMPAY_LANG=uk
#
# --- Экономика и курсы для StreamPay ---
# По умолчанию бот берет курс ЦБ РФ (STREAMPAY_AUTO_FIAT_RATES=1).
# Если вы хотите задать свои жесткие курсы (сколько единиц валюты за 1 рубль), раскомментируйте и измените строки ниже:
# STREAMPAY_RATE_KZT=7
# STREAMPAY_RATE_UAH=0.65
# STREAMPAY_RATE_BYN=0.042
# STREAMPAY_RATE_AZN=0.027
#
# Либо, если хотите оставить курс ЦБ, но накинуть свой процент (маржу) сверху:
# STREAMPAY_FIAT_MARGIN_PERCENT=8.5

# Реферальная ссылка в мини-аппе (username без @). По умолчанию artshopvirts_bot.
# Не используйте старый VITE_BOT_ADDRESS — реф-ссылка берётся только отсюда / TELEGRAM_BOT_USERNAME.
# REFERRAL_BOT_USERNAME=artshopvirts_bot
#
# /start: подпись к баннеру — ровно 2 custom_emoji_id:
# 1) в начале 1-й строки (вместо 👋), 2) в конце 2-й строки (вместо 👇)
WELCOME_STICKER_FILE_IDS=5402498632739996967,5231102735817918643

# Custom emoji перед строкой «Есть трудности с оформлением заказа?…» (кнопка «Как оформить заказ»).
# По умолчанию в коде тот же id; переопределение через .env:
HOW_TO_ORDER_HELP_CUSTOM_EMOJI_ID=5210880311801423356

# (устарело для подписи к видео — раньше «молния»; видео + текст идут через HOW_TO_ORDER_HELP_*)
# HOW_STICKER_FILE_ID=5323761960829862762

# «О магазине»: 4 строки — доллар, молния, бары, цепь (как 🪙⚡🍑⛓)
ABOUT_STICKER_FILE_IDS=5283232570660634549,5323761960829862762,5258330865674494479,5260730055880876557

# «Заказ оформлен» (подпись к фото) — ровно 3 custom_emoji_id:
# 1) в начале 1-й строки (как ✅), 2) у строки срока (как 🕔), 3) в конце последней (как 👇)
ORDER_SUCCESS_STICKER_IDS=5233307140667492238,5258419835922030550,5231102735817918643

# Менеджер / «Продать вирты» (подпись к тому же фото) — 2 id, без срока выдачи:
# 1) в начале 1-й строки (как ✅), 2) в конце «…через кнопку ниже» (как 👇)
ORDER_SUCCESS_MANAGER_STICKER_IDS=5233307140667492238,5231102735817918643

# Выполнение заказа (подпись к images/photo_3.*) — ровно 3 custom_emoji_id:
# 1) «Заказ #… выполнен» (как ✅), 2) «Вирты / данные аккаунта» (как ✅), 3) «Напишите отзыв…» (как 🪙)
ORDER_COMPLETED_STICKER_IDS=5208540237524911208,5260726538302660868,5283232570660634549
# Fallback, если /start-стикеры не отправились (нет WELCOME_STICKER_FILE_IDS / ошибка API):
# WELCOME_PHOTO_URL=https://...
# WELCOME_PHOTO_PATH=images/welcome.jpg
#
# «О магазине» — в одном стиле с WELCOME_PHOTO_PATH / ORDER_* (абсолютно до файла в /srv/.../images/ или относительно bot/):
# ABOUT_SHOP_PHOTO_PATH=/srv/artshopvirts/mini-app-artyom130609/images/photo_4.jpg
# ABOUT_SHOP_PHOTO_PATH=images/photo_4.jpg
# ABOUT_SHOP_PHOTO_URL=https://...

# Фото «заказ оформлен» — положите файл в bot/images/ под одним из имён:
# order-success.jpg | order-success.png | order.jpg | order.png
# или photo_2026-04-07_20-21-21.jpg / .png
# Если имя своё:
# ORDER_SUCCESS_IMAGE_PATH=images/ваш-файл.jpg
# или абсолютный путь:
# ORDER_SUCCESS_IMAGE_PATH=/srv/artshopvirts/mini-app-artyom130609/bot/images/ваш-файл.jpg
#
# Проверка всех картинок и env на сервере: cd bot && npm run build && npm run diag:photos

# Мини-апп шлёт orderKind: virt | account. Для account по умолчанию:
# WebApp «Узнать детали» → /profile?open=currentOrders[&orderId=…] (актуальные заказы).
# Только если нужен сценарий через менеджера (кнопка-ссылка t.me, не WebApp):
# ACCOUNT_ORDER_TEMPLATE=manager
# MANAGER_TELEGRAM_URL=https://t.me/artshopvirts_man
