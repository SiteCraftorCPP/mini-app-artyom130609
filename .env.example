# Домен приложения / webhook (HTTPS)
APP_DOMAIN=https://example.com
# Mini App (кнопка «Открыть магазин»)
MINI_APP_URL=https://example.com
# Баннер /start: публичный HTTPS (предпочтительно на проде) ИЛИ файл ниже
# WELCOME_PHOTO_URL=https://example.com/banner.jpg
# Путь к файлу относительно папки bot/ (jpg/png)
WELCOME_PHOTO_PATH=images/welcome.jpg

# Видео «Как оформить заказ»: путь относительно папки bot/
INSTRUCTION_VIDEO_PATH=images/instruction.mp4

# Telegram Bot API (только на сервере или локально; не публиковать)
TELEGRAM_BOT_TOKEN=
# ID админа в Telegram (число)
TELEGRAM_ADMIN_ID=
# Список ID админов в Telegram (через запятую). Если задан — работает вместе с TELEGRAM_ADMIN_ID
# TELEGRAM_ADMIN_IDS=7600749840,1944803821

# HTTP уведомления бота о заказе (порт слушает процесс бота)
# ORDER_NOTIFY_HTTP_PORT=8788
# ORDER_NOTIFY_HTTP_BIND=127.0.0.1
# ORDER_NOTIFY_SECRET=  # опционально: Bearer для POST /notify/virt-order-success (бэкенд)
# nginx:
# location /notify/virt-order-webapp { proxy_pass http://127.0.0.1:8788/notify/virt-order-webapp; }
# location /notify/sell-virt-webapp { proxy_pass http://127.0.0.1:8788/notify/sell-virt-webapp; }

# --- Фото «заказ оформлен» (отдельно от welcome /start) ---
# На сервере файл должен лежать рядом с ботом:  .../mini-app-.../bot/images/ИМЯ.jpg
# Папка именно images (маленькими буквами). Имена, которые бот ищет сам: order-success.jpg,
# order-success.png, photo_2026-04-07_20-21-21.jpg/.png, order.jpg, order.png
# Если имя своё — раскомментируйте и укажите путь ОТНОСИТЕЛЬНО папки bot/:
# ORDER_SUCCESS_IMAGE_PATH=images/moe-foto-zakaza.jpg
# Или абсолютный путь:
# ORDER_SUCCESS_IMAGE_PATH=/srv/artshopvirts/mini-app-artyom130609/bot/images/moe-foto-zakaza.jpg
# Если файла нет на диске — только тогда URL:
# ORDER_SUCCESS_PHOTO_URL=https://artshopvirts.space/static/order.jpg

# Фронт (Vite)
# TG user id (число) через запятую — доступ к админ-списку «Актуальные заказы» в мини-аппе
# VITE_ADMIN_TELEGRAM_IDS=123456789,987654321
VITE_API_URL=https://api.example.com
# URL POST уведомления о заказе (по умолчанию тот же origin + /notify/virt-order-webapp; на сервере нужен nginx → порт бота)
# VITE_VIRT_ORDER_NOTIFY_URL=https://example.com/notify/virt-order-webapp
# URL POST для кнопки «Продать» (по умолчанию тот же origin + /notify/sell-virt-webapp)
# VITE_SELL_VIRT_NOTIFY_URL=https://example.com/notify/sell-virt-webapp
# Username бота для deep link (без @). Для /start и прочих ссылок на бота.
VITE_BOT_ADDRESS=MiniAppArtyom130609_BOT

# Опционально: внешняя ссылка (не мини-апп), если используете в других местах.
VITE_CHANEL_BUY=
VITE_SUPPORT_CHAT_URL=''
VITE_PRIVACY_POLICY_URL=''
VITE_TERMS_URL=''
VITE_CONTACTS_URL=''
VITE_REVIEWS_URL=''
VITE_CHANNEL_URL=''
# --- Обязательная подписка на канал ---
# ID канала (например -1001234567890). Бот должен быть там администратором!
REQUIRED_CHANNEL_ID=
# Ссылка на канал для кнопки
REQUIRED_CHANNEL_URL=
