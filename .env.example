# Домен приложения / webhook (HTTPS)
APP_DOMAIN=https://example.com
# Mini App (кнопка «Открыть магазин»)
MINI_APP_URL=https://example.com
# Баннер /start: публичный HTTPS (предпочтительно на проде) ИЛИ файл ниже
# WELCOME_PHOTO_URL=https://example.com/banner.jpg
# Путь к файлу относительно папки bot/ (jpg/png)
WELCOME_PHOTO_PATH=images/welcome.jpg

# Видео «Как оформить заказ»: путь относительно папки bot/
INSTRUCTION_VIDEO_PATH=images/instruction.mp4

# Telegram Bot API (только на сервере или локально; не публиковать)
TELEGRAM_BOT_TOKEN=
# ID админа в Telegram (число)
TELEGRAM_ADMIN_ID=

# HTTP уведомления бота о заказе (порт слушает процесс бота)
# ORDER_NOTIFY_HTTP_PORT=8788
# ORDER_NOTIFY_HTTP_BIND=127.0.0.1
# ORDER_NOTIFY_SECRET=  # опционально: Bearer для POST /notify/virt-order-success (бэкенд)
# nginx: location /notify/virt-order-webapp { proxy_pass http://127.0.0.1:8788/notify/virt-order-webapp; }

# Фото в сообщении «заказ оформлен» (достаточно одного способа)
# ORDER_SUCCESS_PHOTO_URL=https://artshopvirts.space/path/to/order-success.jpg
# ORDER_SUCCESS_IMAGE_PATH=images/photo_2026-04-07_20-21-21.jpg  # путь относительно папки bot/

# Фронт (Vite)
VITE_API_URL=https://api.example.com
# URL POST уведомления о заказе (по умолчанию тот же origin + /notify/virt-order-webapp; на сервере нужен nginx → порт бота)
# VITE_VIRT_ORDER_NOTIFY_URL=https://example.com/notify/virt-order-webapp
# Username бота без @ — для LINK_SHARED и кнопок
VITE_BOT_ADDRESS=

VITE_CHANEL_BUY=''
VITE_SUPPORT_CHAT_URL=''
VITE_PRIVACY_POLICY_URL=''
VITE_TERMS_URL=''
VITE_CONTACTS_URL=''
VITE_REVIEWS_URL=''
VITE_CHANNEL_URL=''